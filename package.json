{
  "name": "vertebrae",
  "version": "0.1.0",
  "private": true,
  "description": "Vertebrae - 3D Particle Editor & 3D Asset Creator",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "dev:win": "powershell -ExecutionPolicy Bypass -File .\\run-dev.ps1",
    "build:win": "powershell -ExecutionPolicy Bypass -File .\\run-build.ps1",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "electron ."
  },
  "dependencies": {
    "@types/three": "^0.183.1",
    "jszip": "^3.10.1",
    "pako": "^2.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "fs-extra": "^11.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  }
}
